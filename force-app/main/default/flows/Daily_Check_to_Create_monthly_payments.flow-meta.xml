    <formulas>
        <name>CurrentMonthNumber</name>
        <dataType>Number</dataType>
        <expression>MONTH({!$Flow.CurrentDate})</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>CurrentMonthText</name>
        <dataType>String</dataType>
        <expression>CASE(
  MONTH(TODAY()),
  1, &quot;Enero&quot;,
  2, &quot;Febrero&quot;,
  3, &quot;Marzo&quot;,
  4, &quot;Abril&quot;,
  5, &quot;Mayo&quot;,
  6, &quot;Junio&quot;,
  7, &quot;Julio&quot;,
  8, &quot;Agosto&quot;,
  9, &quot;Septiembre&quot;,
  10, &quot;Octubre&quot;,
  11, &quot;Noviembre&quot;,
  12, &quot;Diciembre&quot;,
  &quot;Desconocido&quot;
)</expression>
    </formulas>
    <formulas>
        <name>CurrentYearNumber</name>
        <dataType>Number</dataType>
        <expression>YEAR($Flow.CurrentDate)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>DaysInPreviousMonth</name>
        <dataType>Number</dataType>
        <expression>DAY(
  DATE(
    {!CurrentYearNumber},
    {!CurrentMonthNumber},
    1
  ) - 1
)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>SignupDay</name>
        <dataType>Number</dataType>
        <expression>DAY({!Loop_Active_Students.Fecha_inscripcion__c})</expression>
