    <decisions>
        <name>Is_Payment_Day</name>
        <label>Is Payment Day?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Loop_Active_Students</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>TODAYDAY</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>StudentSignupDay</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Existing_Payment</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
        <rules>
            <name>EdgeCase_FirstDayAfterShortMonth</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>TODAYDAY</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>SignupDay</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>DaysInPreviousMonth</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Copy_1_of_Get_Existing_Payment</targetReference>
            </connector>
            <label>EdgeCase_FirstDayAfterShortMonth</label>
        </rules>
    </decisions>
